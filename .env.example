# GMO Coin Private API（口座開設後に設定）
# ※ このファイルは .gitignore で除外された .env にコピーして使う
# ※ APIキー・シークレットは絶対に git にコミットしないこと
GMO_API_KEY=
GMO_API_SECRET=

# DRY_RUN: true=実発注なし（シミュレーションのみ） / false=実際に発注
# 最初は必ず true のまま動作確認すること
DRY_RUN=true

# READ_ONLY: true=残高取得のみ許可、発注・キャンセルは例外で停止
# DRY_RUN=false にするときも READ_ONLY=true を維持推奨
READ_ONLY=true

# ログレベル（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# Gmail / SMTP 通知設定
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USERNAME=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
